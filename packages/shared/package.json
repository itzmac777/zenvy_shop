{
  "name": "@zenvy/shared",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "default": "./dist/catalog.js"
    },
    "./orders": {
